{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/app/**",
        "destination": "/app/index.html"
      }
    ]
  },
  "firestore": {
    "database": "(default)",
    "location": "europe-west6",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}